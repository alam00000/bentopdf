# =============================================================================
# BentoPDF Production — Environment Variables (Cainmani Server)
# =============================================================================
# Copy to .env:  cp .env.prod.example .env
# NEVER commit the .env file — it contains secrets
#
# This file is for the production docker-compose.prod.yml (oauth2-proxy + Traefik).
# For build-time variables (branding, WASM URLs), see .env.example.
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------

# Server's LAN IP address (used for sslip.io preview URLs)
SERVER_IP=

# Domain name (e.g., cainmani.cloud)
DOMAIN=

# -----------------------------------------------------------------------------
# OAUTH2-PROXY — Keycloak OIDC Authentication
# -----------------------------------------------------------------------------
# Register a client in Keycloak first:
#   1. Open Keycloak admin: https://auth.DOMAIN/admin/
#   2. Realm: cainmani -> Clients -> Create client
#   3. Client ID: bentopdf-web, Client authentication: ON
#   4. Valid redirect URI: https://pdf.DOMAIN/oauth2/callback
#   5. Web origins: https://pdf.DOMAIN
#   6. Copy the client secret from the Credentials tab
#
# IMPORTANT: Add an Audience mapper to the client:
#   Client scopes -> bentopdf-web-dedicated -> Add mapper -> By configuration
#   -> Audience -> Included Client Audience: bentopdf-web
#   Add to ID token: ON, Add to access token: ON
# -----------------------------------------------------------------------------

# Keycloak OIDC client credentials
OAUTH2_PROXY_CLIENT_ID=bentopdf-web
OAUTH2_PROXY_CLIENT_SECRET=

# Session cookie encryption key
# Generate with: python3 -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
OAUTH2_PROXY_COOKIE_SECRET=
