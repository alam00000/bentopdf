# hiiirePDF Environment Variables
# Copy this file to .env.production and configure as needed.

# CORS Proxy for digital signature certificate chain fetching
VITE_CORS_PROXY_URL=
VITE_CORS_PROXY_SECRET=

# WASM Module URLs
# By default, advanced PDF engines are loaded from same-origin /wasm paths.
# For air-gapped / offline deployments, point these to your internal server.
VITE_WASM_PYMUPDF_URL=/wasm/pymupdf/
VITE_WASM_GS_URL=/wasm/gs/
VITE_WASM_CPDF_URL=/wasm/cpdf/

# OCR assets (optional)
# Set all three together for self-hosted or air-gapped OCR.
# Leave empty to use Tesseract.js runtime defaults.
VITE_TESSERACT_WORKER_URL=
VITE_TESSERACT_CORE_URL=
VITE_TESSERACT_LANG_URL=
VITE_TESSERACT_AVAILABLE_LANGUAGES=
VITE_OCR_FONT_BASE_URL=

# Default UI language (build-time)
# Supported: en, ar, be, fr, de, es, zh, zh-TW, vi, tr, id, it, pt, nl, da, ko, sv, ru
VITE_DEFAULT_LANGUAGE=

# Custom branding (build-time)
# Replace the default hiiirePDF branding with your own.
# Place your logo file in the public/ folder and set the path relative to it.
VITE_BRAND_NAME=
VITE_BRAND_LOGO=
VITE_FOOTER_TEXT=

# Optional repository links used by the header/footer GitHub links and star count.
VITE_SOURCE_REPOSITORY_URL=
VITE_SOURCE_REPOSITORY_API_URL=

# Public canonical URL used for SEO, sitemap, robots.txt, and branded builds.
SITE_URL=
