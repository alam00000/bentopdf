# Hiiire PDF production defaults.
# Timeweb App can use these values as environment variables.

SITE_URL=https://pdf.hiiire.com
VITE_BRAND_NAME=hiiire PDF
VITE_BRAND_LOGO=images/hiiire-pdf-mark.svg
VITE_FOOTER_TEXT=© 2026 hiiire. PDF-инструменты работают локально в браузере.
VITE_DEFAULT_LANGUAGE=ru
VITE_USE_CDN=true
VITE_SOURCE_REPOSITORY_URL=https://github.com/vladkolchik/bentopdf
VITE_SOURCE_REPOSITORY_API_URL=https://api.github.com/repos/vladkolchik/bentopdf
