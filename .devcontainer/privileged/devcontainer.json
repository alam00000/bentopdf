{
  "name": "PaperBridge (Privileged Dev Container)",
  "dockerComposeFile": [
    "../docker-compose.yml",
    "../docker-compose.privileged.yml"
  ],
  "service": "app",
  "workspaceFolder": "/workspaces/paperbridge",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    },
    "ghcr.io/devcontainers-extra/features/ripgrep:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "username": "vscode"
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh ${containerWorkspaceFolder}",
  "postStartCommand": "post_start_failed=0; if ! bash .devcontainer/post-start-bootstrap.sh \"${containerWorkspaceFolder}\" --privileged; then echo 'Post-start bootstrap failed'; post_start_failed=1; fi; if ! bash .devcontainer/setup-dev.sh; then echo 'Setup script failed'; post_start_failed=1; fi; if [ $post_start_failed -ne 0 ]; then echo 'Post-start completed with warnings'; fi",
  "forwardPorts": [5173, 4173],
  "portsAttributes": {
    "5173": {
      "label": "Vite Dev Server",
      "onAutoForward": "openBrowser",
      "protocol": "http",
      "requireLocalPort": true
    },
    "4173": {
      "label": "Preview Server",
      "onAutoForward": "silent",
      "protocol": "http",
      "requireLocalPort": true
    }
  },
  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.env.linux": {
          "HOST": "0.0.0.0"
        }
      },
      "extensions": ["dbaeumer.vscode-eslint"]
    }
  },
  "remoteUser": "vscode",
  "updateRemoteUserUID": true
}
