# Dev-only: route TSA/certificate requests through the built-in Vite CORS proxy
VITE_CORS_PROXY_URL=/cors-proxy
VITE_DEV_HOST=0.0.0.0

# PaperBridge uses its own dashboard as the main UI.
SIMPLE_MODE=false

# QR code base URL. Leave unset to use the server's own origin (/p/{token}).
# Override for a dedicated scan domain: VITE_QR_BASE_URL=https://scan.example.com/p
#VITE_QR_BASE_URL=
